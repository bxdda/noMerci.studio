---
type Props = {
  title: string;
  description: string;
  status: string;
  image: string;
  href: string;
};

const { title, description, status, image, href } = Astro.props;

const isPlayable = status.toLowerCase().includes("play");
---

<a
  href={href}
  class="group relative block overflow-hidden rounded-[2rem] border border-white/10 bg-zinc-900"
>
  <div
    class="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105"
    style={`background-image: url(${image});`}
  ></div>

  <div class="absolute inset-0 bg-black/50 transition duration-300 group-hover:bg-black/35"></div>

  <div class="absolute left-6 top-6 z-20">
    <span
      class={`inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-medium tracking-wide backdrop-blur-md transition-all duration-300
      ${
        isPlayable
          ? "bg-emerald-500/15 text-emerald-300 border border-emerald-400/20 group-hover:bg-emerald-400/20 group-hover:text-emerald-200 group-hover:shadow-[0_0_12px_rgba(16,185,129,0.35)]"
          : "bg-amber-500/15 text-amber-300 border border-amber-400/20 group-hover:bg-amber-400/20 group-hover:text-amber-200 group-hover:shadow-[0_0_12px_rgba(251,191,36,0.35)]"
      } group-hover:scale-[1.05]`}
    >
      <span
        class={`h-1.5 w-1.5 rounded-full transition-all duration-300 ${
          isPlayable
            ? "bg-emerald-400 group-hover:bg-emerald-300"
            : "bg-amber-400 group-hover:bg-amber-300"
        }`}
      ></span>

      {status}
    </span>
  </div>

  <div class="relative z-10 flex min-h-[320px] flex-col justify-end p-8 md:min-h-[380px] md:p-10">
    <h3 class="display-font text-3xl font-semibold md:text-5xl">
      {title}
    </h3>

    <p class="mt-3 max-w-xl text-sm leading-7 text-zinc-300 md:text-base">
      {description}
    </p>
  </div>
</a>