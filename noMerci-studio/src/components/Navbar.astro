---
import SiteMenu from "./SiteMenu";
---

<nav class="fixed inset-x-0 top-0 z-50 px-4 md:px-6">
  <div class="mx-auto max-w-7xl overflow-visible">
    <div class="relative -mt-4 overflow-hidden rounded-[2rem] border border-[#0d0d0d] bg-[#0d0d0d] px-5 pb-3 pt-7 shadow-[0_10px_30px_rgba(0,0,0,0.3)] md:px-7 md:pb-4 md:pt-8">
      <div class="flex items-center justify-between">
        <a
          href="/"
          class="text-sm font-medium tracking-[0.08em] text-white transition hover:text-zinc-300"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          noMerci
        </a>

        <SiteMenu client:load />
      </div>
    </div>
  </div>
</nav>