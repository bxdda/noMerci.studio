---
interface Props {
  heading: string;
  text: string[];
}

const { heading, text } = Astro.props;
---

<section class="max-w-3xl">
  <h2 class="text-xl font-medium tracking-[-0.02em] text-white md:text-2xl">
    {heading}
  </h2>

  <div class="mt-4 space-y-4 text-sm leading-7 text-zinc-400 md:text-base">
    {text.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>
</section>